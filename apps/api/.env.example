# Environment
ENV=dev
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Database
# For local compose networking use host "postgres"
DATABASE_URL=postgresql+psycopg://simu:simu_password_change_me@postgres:5432/simutrader

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
WORKER_CONCURRENCY=2
BACKTEST_EXEC_MODE=async
# Dev-only override for sync execution in non-dev environments
ALLOW_SYNC_EXECUTION=false

# Data paths (inside container)
DATA_DIR=/app/data
PARQUET_DIR=/app/data/processed
DUCKDB_PATH=/app/data/processed/simutrader.duckdb
DATA_SNAPSHOT_ID=local_snapshot_2026-01-22

# Portfolio base currency + FX symbols
BASE_CURRENCY=USD
FX_SYMBOL_USDINR=USDINR

# Security (local dev values; change in prod)
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Finance defaults (all configurable in strategy JSON too)
DEFAULT_COMMISSION_BPS=1.0
DEFAULT_SLIPPAGE_BPS=2.0
DEFAULT_MARGIN_DAILY_INTEREST_BPS=1.5
DEFAULT_SHORT_BORROW_DAILY_BPS=1.0
