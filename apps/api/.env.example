# Environment
ENV=dev
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Idempotency-Key
TRUSTED_HOSTS=localhost,127.0.0.1,::1

# Database
# For local compose networking use host "postgres"
DATABASE_URL=postgresql+psycopg://simu:simu_password_change_me@postgres:5432/simutrader

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Dedicated app-cache + lock Redis usage (keep separate from broker/backend DBs)
REDIS_CACHE_URL=redis://redis:6379/2
REDIS_LOCK_URL=redis://redis:6379/3
REDIS_CACHE_PREFIX=simutrader:cache
REDIS_LOCK_PREFIX=simutrader:lock
RUN_STATUS_CACHE_TTL_SECONDS=30
RUN_SUMMARY_CACHE_TTL_SECONDS=120
TOP_HOLDINGS_CACHE_TTL_SECONDS=120
REDIS_LOCK_TIMEOUT_SECONDS=3600
WORKER_CONCURRENCY=1
DUCKDB_READ_ONLY=true
CELERY_TASK_TIME_LIMIT_SECONDS=3600
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=3300
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_DELAY_SECONDS=30
STALE_RUN_TIMEOUT_SECONDS=7200
STALE_QUEUED_TIMEOUT_SECONDS=900
BACKTEST_EXEC_MODE=async
# Dev-only override for sync execution in non-dev environments
ALLOW_SYNC_EXECUTION=false
# Dedupe window for POST /backtests Idempotency-Key handling
BACKTEST_IDEMPOTENCY_WINDOW_SECONDS=300
MAX_ACTIVE_RUNS_PER_GUEST=5
MAX_ACTIVE_RUNS_PER_USER=20
TRUSTED_USER_HEADER_ENABLED=true
TRUSTED_USER_HEADER_PROXY_SECRET=

# Data paths (inside container)
DATA_DIR=/app/data
PARQUET_DIR=/app/data/processed
DUCKDB_PATH=/app/data/processed/simutrader.duckdb
DATA_SNAPSHOT_ID=local_snapshot_2026-01-22

# Portfolio base currency + FX symbols
BASE_CURRENCY=USD
FX_SYMBOL_USDINR=USDINR

# Security (local dev values; change in prod)
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
GUEST_COOKIE_SIGNING_SECRET=dev-only-guest-cookie-secret

# Finance defaults (all configurable in strategy JSON too)
DEFAULT_COMMISSION_BPS=1.0
DEFAULT_SLIPPAGE_BPS=2.0
DEFAULT_MARGIN_DAILY_INTEREST_BPS=1.5
DEFAULT_SHORT_BORROW_DAILY_BPS=1.0
