# Compose-level config (safe defaults for local dev)
COMPOSE_PROJECT_NAME=simutrader

# Ports
WEB_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Postgres (local dev only)
POSTGRES_USER=simu
POSTGRES_PASSWORD=simu_password_change_me
POSTGRES_DB=simutrader

# Data snapshot label (for run provenance)
DATA_SNAPSHOT_ID=local_snapshot_2026-01-22

# Optional: base currency for reports
BASE_CURRENCY=USD

# Data paths
DATA_DIR=./data
PARQUET_DIR=./data/processed
DUCKDB_PATH=./data/processed/simutrader.duckdb

# Backtest execution
BACKTEST_EXEC_MODE=async
